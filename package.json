{
  "name": "icms",
  "version": "0.1.4",
  "description": "Inventory and Customer Management System - Desktop",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sunshinepowertronics/Electron_ICMS.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "publish": "npm run build && electron-builder --publish always"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.0.1",
    "serialport": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.sunshinepowertronics.icms",
    "productName": "ICMS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "sunshinepowertronics",
        "repo": "Electron_ICMS"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
